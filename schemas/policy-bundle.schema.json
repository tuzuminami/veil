{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tuzuminami.github.io/veil/schemas/policy-bundle.schema.json",
  "title": "PolicyBundleDraft",
  "type": "object",
  "required": ["name", "version", "defaultAction", "rules"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "defaultAction": { "enum": ["BLOCK", "ESCALATE"] },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/rule" }
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "required": ["id", "priority", "effect", "match", "reasonCode"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "priority": { "type": "integer", "minimum": 0 },
        "effect": { "enum": ["ALLOW", "TRANSFORM", "REQUIRE_CONFIRMATION", "BLOCK", "ESCALATE"] },
        "match": {
          "type": "object",
          "required": ["field", "operator"],
          "properties": {
            "field": { "type": "string", "minLength": 1 },
            "operator": { "enum": ["equals", "contains", "absent"] },
            "value": { "type": "string" }
          }
        },
        "reasonCode": { "type": "string", "minLength": 1 },
        "obligations": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
