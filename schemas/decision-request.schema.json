{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tuzuminami.github.io/veil/schemas/decision-request.schema.json",
  "title": "DecisionRequest",
  "type": "object",
  "required": ["policyId", "version", "input"],
  "properties": {
    "policyId": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "input": { "type": "object" },
    "adapterResult": {
      "type": "object",
      "properties": {
        "status": { "enum": ["ok", "unknown", "timeout"] },
        "source": { "type": "string" },
        "result": { "enum": ["ALLOW", "TRANSFORM", "REQUIRE_CONFIRMATION", "BLOCK", "ESCALATE"] }
      }
    }
  }
}
