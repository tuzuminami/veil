{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tuzuminami.github.io/veil/schemas/decision-request.schema.json",
  "title": "DecisionRequest",
  "oneOf": [
    {
      "title": "LegacyDecisionRequest",
      "type": "object",
      "required": ["policyId", "input"],
      "additionalProperties": false,
      "properties": {
        "policyId": { "type": "string", "minLength": 1, "pattern": ".*\\S.*" },
        "version": { "type": "string", "minLength": 1, "pattern": ".*\\S.*" },
        "input": { "type": "object" },
        "adapterResult": { "$ref": "#/$defs/adapterResult" }
      }
    },
    {
      "title": "TypedDecisionRequest",
      "type": "object",
      "required": [
        "policyId",
        "input",
        "type",
        "agent",
        "resource",
        "dataClassification",
        "model",
        "estimatedCost",
        "attributes"
      ],
      "additionalProperties": false,
      "properties": {
        "policyId": { "type": "string", "minLength": 1, "pattern": ".*\\S.*" },
        "version": { "type": "string", "minLength": 1, "pattern": ".*\\S.*" },
        "input": { "type": "object" },
        "type": { "enum": ["model_call", "tool_call"] },
        "agent": {
          "type": "object",
          "required": ["id"],
          "properties": {
            "id": { "type": "string", "minLength": 1, "pattern": ".*\\S.*" },
            "type": { "type": "string", "minLength": 1, "pattern": ".*\\S.*" }
          },
          "additionalProperties": false
        },
        "resource": {
          "type": "object",
          "required": ["id", "type", "classification"],
          "properties": {
            "id": { "type": "string", "minLength": 1, "pattern": ".*\\S.*" },
            "type": { "type": "string", "minLength": 1, "pattern": ".*\\S.*" },
            "classification": { "$ref": "#/$defs/dataClassification" }
          },
          "additionalProperties": false
        },
        "dataClassification": { "$ref": "#/$defs/dataClassification" },
        "model": {
          "type": "object",
          "required": ["provider", "id"],
          "properties": {
            "provider": { "type": "string", "minLength": 1, "pattern": ".*\\S.*" },
            "id": { "type": "string", "minLength": 1, "pattern": ".*\\S.*" }
          },
          "additionalProperties": false
        },
        "estimatedCost": { "type": "number", "minimum": 0 },
        "attributes": { "type": "object" },
        "adapterResult": { "$ref": "#/$defs/adapterResult" }
      }
    }
  ],
  "$defs": {
    "dataClassification": {
      "enum": ["public", "internal", "confidential", "restricted"]
    },
    "adapterResult": {
      "type": "object",
      "properties": {
        "status": { "enum": ["ok", "unknown", "timeout"] },
        "source": { "type": "string" },
        "result": { "enum": ["ALLOW", "TRANSFORM", "REQUIRE_CONFIRMATION", "BLOCK", "ESCALATE"] }
      },
      "additionalProperties": false
    }
  }
}
