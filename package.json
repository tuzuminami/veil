{
  "name": "@tuzuminami/veil",
  "version": "1.0.1",
  "description": "Fail-closed policy decision point for AI agent tool and model execution.",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://github.com/tuzuminami/veil#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuzuminami/veil.git"
  },
  "bugs": {
    "url": "https://github.com/tuzuminami/veil/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": "./src/index.js",
    "./auth": "./src/auth/oidc-auth.js",
    "./postgres": "./src/adapters/postgres-store.js",
    "./migrations": "./src/migrations/postgres-runner.js",
    "./sdk": "./src/sdk/client.js",
    "./runtime": "./src/runtime/production.js",
    "./server": "./src/transport/http-server.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "veil-migrate": "./bin/veil-migrate.mjs"
  },
  "files": [
    "bin",
    "src",
    "openapi",
    "schemas",
    "migrations",
    "examples",
    "docs/adr",
    "docs/runbooks",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "node scripts/build-check.mjs",
    "test": "node --test \"tests/**/*.test.js\"",
    "audit": "pnpm audit --prod --audit-level=low",
    "check:package": "node scripts/package-smoke.mjs",
    "check:relay-enforcement": "node --experimental-strip-types scripts/check-relay-enforcement-contract.mjs",
    "check:private-boundary": "node scripts/check-private-boundary.mjs",
    "check:release-artifact": "node scripts/check-release-artifact.mjs",
    "check:published-release-artifact": "node scripts/check-release-artifact.mjs --published",
    "check:release": "node scripts/release-check.mjs",
    "migrate": "node bin/veil-migrate.mjs",
    "verify": "pnpm run build && pnpm run test && pnpm run check:private-boundary && pnpm run check:package && pnpm run check:release"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "jose": "6.2.3",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "yaml": "2.9.0"
  }
}
